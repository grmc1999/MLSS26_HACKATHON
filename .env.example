# MLSS26_HACKATHON Environment Variables
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (required for LLM agents)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Kaggle API Credentials (for downloading datasets)
# Get your key at https://www.kaggle.com/settings
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key_hex
KAGGLE_CONFIG_DIR=.kaggle

# CDS API Key (for ERA5 data downloads - format: UID:API-KEY)
# Get from https://cds.climate.copernicus.eu/api-how-to
CDS_API_KEY=

# Fast model for summarization and lightweight tasks
FAST_MODEL=openai/gpt-oss-20b:free

# Logging directory
LOG_DIR=logs

# Dashboard configuration
DASHBOARD_BACKEND_PORT=8000
DASHBOARD_FRONTEND_PORT=3000

# Database for dashboard
DATABASE_URL=sqlite:///dashboard.db

# FalkorDB (Flu Literature Context RAG - knowledge graph)
# Start locally with scripts/start_falkordb.sh
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH_NAME=flu_literature
